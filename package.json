{
  "name": "anything-ai",
  "version": "1.0.0",
  "description": "Anything AI - Minimal AI Desktop Assistant (React + Electron + Express + SQLite + Gemini)",
  "main": "electron.js",
  "private": true,
  "scripts": {
    "dev:frontend": "vite --config frontend/vite.config.js",
    "dev:backend": "node backend/server.js",
    "dev": "concurrently -k -n FRONTEND,BACKEND -c blue,green \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "start": "concurrently -k -n FRONTEND,BACKEND,ELECTRON -c blue,green,magenta \"npm run dev:frontend\" \"npm run dev:backend\" \"npm run dev:electron\"",
    "build:frontend": "vite build --config frontend/vite.config.js"
  },
  "dependencies": {
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "better-sqlite3": "^11.3.0",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "@google/generative-ai": "^0.21.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "electron": "^31.3.0",
    "vite": "^5.4.2",
    "@vitejs/plugin-react": "^4.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.1",
    "tailwindcss": "^3.4.10",
    "postcss": "^8.4.41",
    "autoprefixer": "^10.4.20",
    "lucide-react": "^0.441.0",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0"
  }
}
